// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_DATABASE_URL")
  relationMode = "prisma"
}

// المستخدم (المدرس)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// الأماكن (الفروع)
model Location {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  groups    Group[]
}

// المستويات (10 مستويات ثابتة)
model Level {
  id          String   @id @default(cuid())
  number      Int      @unique
  name        String
  monthsCount Int      @default(3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  groups      Group[]
  students    Student[]
}

// المجموعات
model Group {
  id            String   @id @default(cuid())
  name          String
  locationId    String
  levelId       String
  sessionTime   String?  // وقت الحصة الافتراضي
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  level         Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  students      Student[]
  sessions      Session[]
  attendances   Attendance[]
}

// الطلاب
model Student {
  id           String   @id @default(cuid())
  name         String
  phone        String?
  notes        String?  @db.Text
  startDate    DateTime @default(now())
  levelId      String
  groupId      String
  isArchived   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  level        Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  evaluations  Evaluation[]
  attendances  Attendance[]
}

// الحصص (للتقييم)
model Session {
  id            String   @id @default(cuid())
  groupId       String
  levelMonth    Int
  sessionNumber Int
  date          DateTime @default(now())
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  evaluations   Evaluation[]

  @@unique([groupId, levelMonth, sessionNumber])
}

// التقييمات
model Evaluation {
  id               String   @id @default(cuid())
  sessionId        String
  studentId        String
  isPresent        Boolean  @default(true)
  behavior         Int?
  focus            Int?
  speed            Int?
  imaginationWrite Int?
  imaginationVerbal Int?
  abacus           Int?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  session          Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
}

// الحضور والغياب (صفحة منفصلة)
model Attendance {
  id           String   @id @default(cuid())
  groupId      String
  studentId    String
  date         DateTime @default(now())
  startTime    DateTime?
  endTime      DateTime?
  sessionTime  String?  // وقت الحصة
  isPresent    Boolean  @default(true)
  notes        String?  @db.Text
  weekNumber   Int?     // رقم الأسبوع
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId, date])
}
